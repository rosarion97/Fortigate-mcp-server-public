# Copy this file to .env and fill in the required values.
# The .env file is gitignored — never commit real credentials.
#
# 1) FORTIGATE_API_TOKEN — REST API token. Generate it on the FortiGate:
#       System -> Administrators -> Create New -> REST API Admin
#    Assign an administrator profile (accprofile) scoped to READ-ONLY, set a
#    Trusthost that matches where this container runs, then copy the token
#    shown once at creation. Store it securely; it is never displayed again.
#
# 2) FORTIGATE_HOST — management host/IP of the FortiGate this instance serves
#    (e.g. 192.0.2.1 or fw01.example.com).
#
# 3) FORTIGATE_VDOM — the VDOM this server instance is pinned to. Every tool
#    is scoped to this VDOM; the model cannot target a different one. Use
#    'root' if VDOMs are not enabled. Run a second container with its own
#    .env to serve a second VDOM.
#
# All three above are REQUIRED. The server fails fast on startup if any is
# unset.

FORTIGATE_API_TOKEN=your_token_here
FORTIGATE_HOST=your_fortigate_host_here
FORTIGATE_VDOM=root

# Optional: HTTPS admin port (default 443).
# FORTIGATE_PORT=443

# Optional: TLS certificate verification. Defaults to "yes". Set to "no" only
# if the FortiGate presents a self-signed certificate you cannot validate.
# FORTIGATE_VERIFY_SSL=yes

# Optional: cap the size (bytes of JSON) of any single tool response.
# Prevents huge endpoints like the session table or log queries from blowing
# past the model's context window. The server returns a truncation envelope
# with a `_hint` field when this cap kicks in. Default 120000 (~30k tokens).
# FORTIGATE_MAX_RESPONSE_BYTES=120000
